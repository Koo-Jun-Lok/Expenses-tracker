-- Create database
CREATE DATABASE IF NOT EXISTS expense_tracker;
USE expense_tracker;

-- Users table (for authentication)
CREATE TABLE users (
    id INT PRIMARY KEY AUTO_INCREMENT,
    username VARCHAR(50) UNIQUE NOT NULL,
    email VARCHAR(100) UNIQUE NOT NULL,
    password VARCHAR(255) NOT NULL,
    full_name VARCHAR(100),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP，
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);

-- Expenses table (7 fields as required)
CREATE TABLE expenses (
    id INT PRIMARY KEY AUTO_INCREMENT,                    -- Integer, Unique
    user_id INT NOT NULL,                                 -- Integer (links to users)
    amount DECIMAL(10,2) NOT NULL,                        -- Integer/Decimal type
    category VARCHAR(50) NOT NULL,                        -- String
    description TEXT,                                     -- String
    expense_date DATE NOT NULL,                           -- Date
    location VARCHAR(100),                                -- String
    receipt_image VARCHAR(255),                           -- String (for Member 2)
    currency VARCHAR(10) DEFAULT 'MYR',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
);

-- Expense categories table
CREATE TABLE categories (
    id INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(50) NOT NULL,
    color VARCHAR(7) DEFAULT '#3B82F6',
    icon VARCHAR(50)
);

